{
  "name": "declutter-api",
  "version": "0.1.0",
  "private": true,
  "description": "Declutter NestJS API for Lagos peer-to-peer marketplace.",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
